{
  "name": "threejs-scenes",
  "version": "1.0.0",
  "description": "Strictly-typed factories and interfaces for building production-quality vanilla three.js (WebGL2) scenes: renderer/loop/dispose scaffolding, cameras, instancing, shaders, lighting, particles, post-processing, voxels, infinite worlds, and the context-injection module architecture distilled from a shipping project.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./camera": {
      "types": "./dist/camera/index.d.ts",
      "import": "./dist/camera/index.js"
    },
    "./instancing": {
      "types": "./dist/instancing/index.d.ts",
      "import": "./dist/instancing/index.js"
    },
    "./materials": {
      "types": "./dist/materials/index.d.ts",
      "import": "./dist/materials/index.js"
    },
    "./lighting": {
      "types": "./dist/lighting/index.d.ts",
      "import": "./dist/lighting/index.js"
    },
    "./particles": {
      "types": "./dist/particles/index.d.ts",
      "import": "./dist/particles/index.js"
    },
    "./post": {
      "types": "./dist/post/index.d.ts",
      "import": "./dist/post/index.js"
    },
    "./post/webgpu": {
      "types": "./dist/post/webgpu/index.d.ts",
      "import": "./dist/post/webgpu/index.js"
    },
    "./procedural": {
      "types": "./dist/procedural/index.d.ts",
      "import": "./dist/procedural/index.js"
    },
    "./voxels": {
      "types": "./dist/voxels/index.d.ts",
      "import": "./dist/voxels/index.js"
    },
    "./architecture": {
      "types": "./dist/architecture/index.d.ts",
      "import": "./dist/architecture/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "readme.md"
  ],
  "sideEffects": false,
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint lib",
    "smoke": "bun run lib/__smoke__.ts",
    "test": "bun run typecheck && bun run smoke"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuomashatakka/threejs-scenes-skill.git"
  },
  "keywords": [
    "threejs",
    "three",
    "webgl",
    "webgl2",
    "3d",
    "scene",
    "instancing",
    "post-processing",
    "voxels",
    "procedural",
    "shaders",
    "factories"
  ],
  "author": "Tuomas Hatakka",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tuomashatakka/threejs-scenes-skill/issues"
  },
  "homepage": "https://github.com/tuomashatakka/threejs-scenes-skill#readme",
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@tuomashatakka/eslint-config": "^3.2.2",
    "@types/three": "^0.184.1",
    "three": "^0.184.0",
    "typescript": "^6.0.3"
  }
}
